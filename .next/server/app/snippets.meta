{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/snippets/layout,_N_T_/snippets/page,_N_T_/snippets"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/snippets/__PAGE__",
    "/snippets",
    "/_index",
    "/_head"
  ]
}